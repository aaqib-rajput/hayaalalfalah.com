{
  "name": "notification-service",
  "version": "1.0.0",
  "description": "Notification service for MosqueConnect (Email, SMS, Push)",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "test": "vitest"
  },
  "dependencies": {
    "@mosqueconnect/shared-types": "*",
    "@mosqueconnect/shared-utils": "*",
    "@prisma/client": "^5.10.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "nodemailer": "^6.9.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.14",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^5.10.2",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
