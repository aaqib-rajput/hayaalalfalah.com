{
  "name": "identity-service",
  "version": "1.0.0",
  "description": "Auth and Identity service for MosqueConnect",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prisma:generate": "prisma generate",
    "test": "vitest"
  },
  "dependencies": {
    "@mosqueconnect/shared-types": "*",
    "@mosqueconnect/shared-utils": "*",
    "@prisma/client": "^5.10.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^5.10.2",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
