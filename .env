# --- Global Configuration ---
NODE_ENV=production
NEXT_PUBLIC_API_URL=http://localhost:3000/api
INTERNAL_API_URL=http://api-gateway:80/api

# --- Database & Cache ---
DATABASE_URL=postgresql://mosque_admin:mosque_password@localhost:5432/mosque_db
REDIS_URL=redis://localhost:6379

# --- Security & Auth ---
JWT_SECRET=generate-a-secure-random-secret
JWT_REFRESH_SECRET=generate-another-secure-random-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- Service Ports ---
IDENTITY_SERVICE_PORT=4001
MOSQUE_SERVICE_PORT=4002
PRAYER_EVENT_SERVICE_PORT=4003
COMMUNITY_SERVICE_PORT=4004
GOVERNANCE_SERVICE_PORT=4005
LIBRARY_SERVICE_PORT=4006
FINANCE_SERVICE_PORT=4007

# --- Prebuilt Docker Images / Local Docker Startup ---
IMAGE_PREFIX=mosqueconnect-production
IMAGE_TAG=latest
GATEWAY_PORT=80
FRONTEND_PORT=3000
POSTGRES_PORT=5433
REDIS_PORT=6379
AUTH_COOKIE_NAME=mc_access_token
AUTH_COOKIE_MAX_AGE_MS=86400000
LOG_LEVEL=info
